<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>UltraFit</title>
    <link rel="stylesheet" href="/estilos.css">
</head>

<body>

<header>
    <div id="logo">UltraFit</div>

    <nav>
        <ul>
            <li><a href="#inicio">Inicio</a></li>
            <li><a href="#precios">Precios</a></li>
            <li><a href="#clases">Clases</a></li>
            <li><a href="#ubicacion">Ubicación</a></li>
            <li><a href="#pedirinformacion">Pedir Información</a></li>
            <li><a href="/login">Iniciar sesión</a></li>
        </ul>
    </nav>
</header>

<main>

    <!-- INICIO -->
    <section id="inicio">
        <h2>Bienvenidos a UltraFit</h2>
        <p>El mejor gimnasio del país. Empieza hoy tu cambio con nosotros.</p>

        <a href="#precios">
            <button>Unirse ahora</button>
        </a>

        <a href="/login">
            <button>Ya eres Miembro? Iniciar</button>
        </a>
    </section>

    <!-- PRECIOS -->
    <section id="precios">
        <h2>Elige tu plan</h2>

        <div class="Tarifas">

            <article class="Panel Precio Basico">
                <h3>Plan Básico</h3>
                <p class="precio">30€/mes</p>
                <ul>
                    <li>Acceso al gimnasio</li>
                    <li>Horario 8:00 - 22:00</li>
                    <li>Sin piscina</li>
                </ul>
                <button>Elegir plan</button>
            </article>

            <article class="Panel Precio Pro">
                <h3>Plan Pro</h3>
                <p class="precio">50€/mes</p>
                <ul>
                    <li>Acceso al gimnasio</li>
                    <li>Horario 8:00 - 22:00</li>
                    <li>Acceso a piscina</li>
                </ul>
                <button>Elegir plan</button>
            </article>

            <article class="Panel Precio Premium">
                <h3>Plan Premium</h3>
                <p class="precio">80€/mes</p>
                <ul>
                    <li>Acceso al gimnasio</li>
                    <li>Horario 24h</li>
                    <li>Piscina incluida</li>
                    <li>SPA y masajes</li>
                </ul>
                <button>Elegir plan</button>
            </article>

        </div>
    </section>

    <!-- CLASES -->
    <section id="clases">
        <div class="seccion-interior">
            <div class="servicios-cabecera">
                <div class="seccion-etiqueta">Nuestras clases</div>
                <h2 class="seccion-titulo">ENTRENA<br><span class="acento">SIN LÍMITES</span></h2>
                <p class="seccion-descripcion">Aquí encontrarás las clases disponibles actualmente.</p>
            </div>
        </div>
    </section>

    <!-- UBICACIÓN -->
    <section id="ubicacion">
        <h2>Ubicación</h2>

        <iframe 
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3151.835434509374!2d144.953736315316!3d-37.81627977975195!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x6ad642af0f11fd81%3A0xf577d9a651e5e0!2sFederation%20Square!5e0!3m2!1sen!2sau!4v1618317045678!5m2!1sen!2sau"
            width="600" height="450" style="border:0;" allowfullscreen loading="lazy">
        </iframe>
    </section>

    <!-- FORMULARIO -->
    <section id="pedirinformacion">

        <h2>Solicitar Información</h2>

        <form action="/contact" method="post" onsubmit="return validateContactForm()">


            <div class="formulario_fila">
                <div class="formulario_unidad">
                    <label for="nombre">Nombre</label>
                    <input type="text" id="nombre" name="nombre" placeholder="Tu nombre" required>
                </div>

                <div class="formulario_unidad">
                    <label for="apellido">Apellido</label>
                    <input type="text" id="apellido" name="apellido" placeholder="Tu apellido" required>
                </div>
            </div>

            <div class="formulario_fila">
                <div class="formulario_unidad">
                    <label for="email">Email</label>
                    <input type="email" id="email" name="email" placeholder="Tu email" required>
                </div>

                <div class="formulario_unidad">
                    <label for="telefono">Teléfono</label>
                    <input type="tel" id="telefono" name="telefono" placeholder="Tu teléfono" required>
                </div>
            </div>

            <div class="formulario_unidad">
                <label for="centro">Centro del gimnasio</label>
                <select id="centro" name="centro" required>
                    <option value="">Seleccione un centro</option>
                    <option value="madrid">Madrid</option>
                    <option value="barcelona">Barcelona</option>
                    <option value="vigo">Vigo</option>
                    <option value="valencia">Valencia</option>
                </select>
            </div>

            <div class="formulario_unidad">
                <label for="mensaje">Mensaje</label>
                <textarea id="mensaje" name="mensaje" placeholder="Duda o comentario" required></textarea>
            </div>

            <button type="submit">Solicitar Información</button>

        </form>

    </section>

</main>

<footer>
    <div class="footer_inferior">
        <p>&copy; 2024 UltraFit. Todos los derechos reservados.</p>
    </div>
</footer>
<script src="/app.js"></script>

</body>
</html>
