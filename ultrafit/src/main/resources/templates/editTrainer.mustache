<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Edit Trainer | UltraFit</title>
    <link rel="stylesheet" href="/estilos.css">
</head>

<body>

<header>
    <div id="logo">UltraFit</div>
    <nav>
        <ul>
            <li><a href="/">Inicio</a></li>
            <li><a href="/dashboard">Dashboard</a></li>
            <li><a href="/members">Members</a></li>
            <li><a href="/trainers">Trainers</a></li>
            <li><a href="/logout">Logout</a></li>
        </ul>
    </nav>
</header>

<main>

    <section>
        <h2>Edit Trainer</h2>

        <form action="/trainers/update" method="post">

            <input type="hidden" name="id" value="{{trainer.id}}">

            <div class="formulario_fila">
                <div class="formulario_unidad">
                    <label>Name</label>
                    <input type="text" name="name" value="{{trainer.name}}" required>
                </div>
                <div class="formulario_unidad">
                    <label>Specialty</label>
                    <input type="text" name="specialty" value="{{trainer.specialty}}" required>
                </div>
            </div>

            <div class="formulario_unidad">
                <label>Years of experience</label>
                <input type="number" name="experienceYears" value="{{trainer.experienceYears}}" min="0" required>
            </div>

            <button type="submit">Update Trainer</button>

        </form>

        <a href="/trainers">
            <button style="margin-top:20px;">Back</button>
        </a>

    </section>

</main>

<footer>
    <div class="footer_inferior">
        <p>&copy; 2024 UltraFit. All rights reserved.</p>
    </div>
</footer>

</body>
</html>