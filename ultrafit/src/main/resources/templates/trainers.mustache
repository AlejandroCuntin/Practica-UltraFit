<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Trainers | UltraFit</title>
    <link rel="stylesheet" href="/estilos.css">
</head>

<body>

<header>
    <div id="logo">UltraFit</div>
    <nav>
        <ul>
            <li><a href="/">Inicio</a></li>
            <li><a href="/dashboard">Dashboard</a></li>
            <li><a href="/members">Members</a></li>
            <li><a href="/trainers">Trainers</a></li>
            <li><a href="/logout">Logout</a></li>
        </ul>
    </nav>
</header>

<main>

    <section>
        <h2>Trainers</h2>

        <ul>
            {{#trainers}}
                <li>
                    <strong>{{name}}</strong> — {{specialty}} — {{experienceYears}} years

                    <a href="/trainers/edit?id={{id}}">
                        <button>Edit</button>
                    </a>

                    <form action="/trainers/delete" method="post" style="display:inline;">
                        <input type="hidden" name="id" value="{{id}}">
                        <button type="submit">Delete</button>
                    </form>
                </li>
            {{/trainers}}

            {{^trainers}}
                <p>No trainers yet.</p>
            {{/trainers}}
        </ul>
    </section>

    <section>
        <h3>Create Trainer</h3>

        <form action="/trainers/create" method="post">

            <div class="formulario_fila">
                <div class="formulario_unidad">
                    <label>Name</label>
                    <input type="text" name="name" placeholder="Name" required>
                </div>
                <div class="formulario_unidad">
                    <label>Specialty</label>
                    <input type="text" name="specialty" placeholder="Specialty" required>
                </div>
            </div>

            <div class="formulario_unidad">
                <label>Years of experience</label>
                <input type="number" name="experienceYears" placeholder="Years of experience" min="0" required>
            </div>

            <button type="submit">Create Trainer</button>

        </form>
    </section>

</main>

<footer>
    <div class="footer_inferior">
        <p>&copy; 2024 UltraFit. All rights reserved.</p>
    </div>
</footer>

<script src="/app.js"></script>
</body>
</html>